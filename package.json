{
  "name": "copilot-scheduler",
  "displayName": "Copilot Scheduler",
  "description": "Schedule automatic AI prompts with cron expressions",
  "version": "1.1.1",
  "publisher": "yamapan",
  "license": "CC-BY-NC-SA-4.0",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/aktsmm/vscode-copilot-scheduler"
  },
  "bugs": {
    "url": "https://github.com/aktsmm/vscode-copilot-scheduler/issues"
  },
  "homepage": "https://github.com/aktsmm/vscode-copilot-scheduler#readme",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "copilot",
    "scheduler",
    "cron",
    "automation",
    "prompt"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copilotScheduler.createTask",
        "title": "%command.createTask%",
        "category": "%extension.title%"
      },
      {
        "command": "copilotScheduler.createTaskGui",
        "title": "%command.createTaskGui%",
        "category": "%extension.title%",
        "icon": "$(add)"
      },
      {
        "command": "copilotScheduler.listTasks",
        "title": "%command.listTasks%",
        "category": "%extension.title%"
      },
      {
        "command": "copilotScheduler.deleteTask",
        "title": "%command.deleteTask%",
        "category": "%extension.title%",
        "icon": "$(trash)"
      },
      {
        "command": "copilotScheduler.toggleTask",
        "title": "%command.toggleTask%",
        "category": "%extension.title%",
        "icon": "$(debug-pause)"
      },
      {
        "command": "copilotScheduler.enableTask",
        "title": "%command.enableTask%",
        "category": "%extension.title%",
        "icon": "$(play-circle)"
      },
      {
        "command": "copilotScheduler.disableTask",
        "title": "%command.disableTask%",
        "category": "%extension.title%",
        "icon": "$(stop-circle)"
      },
      {
        "command": "copilotScheduler.runNow",
        "title": "%command.runNow%",
        "category": "%extension.title%",
        "icon": "$(play)"
      },
      {
        "command": "copilotScheduler.copyPrompt",
        "title": "%command.copyPrompt%",
        "category": "%extension.title%",
        "icon": "$(copy)"
      },
      {
        "command": "copilotScheduler.editTask",
        "title": "%command.editTask%",
        "category": "%extension.title%",
        "icon": "$(edit)"
      },
      {
        "command": "copilotScheduler.duplicateTask",
        "title": "%command.duplicateTask%",
        "category": "%extension.title%"
      },
      {
        "command": "copilotScheduler.moveToCurrentWorkspace",
        "title": "%command.moveToCurrentWorkspace%",
        "category": "%extension.title%",
        "icon": "$(pin)"
      },
      {
        "command": "copilotScheduler.openSettings",
        "title": "%command.openSettings%",
        "category": "%extension.title%",
        "icon": "$(settings-gear)"
      },
      {
        "command": "copilotScheduler.showVersion",
        "title": "%command.showVersion%",
        "category": "%extension.title%",
        "icon": "$(info)"
      },
      {
        "command": "copilotScheduler.showExecutionHistory",
        "title": "%command.showExecutionHistory%",
        "category": "%extension.title%",
        "icon": "$(history)"
      },
      {
        "command": "copilotScheduler.dumpModelCatalog",
        "title": "%command.dumpModelCatalog%",
        "category": "%extension.title%"
      }
    ],
    "configuration": {
      "title": "%extension.title%",
      "properties": {
        "copilotScheduler.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%config.enabled%"
        },
        "copilotScheduler.defaultScope": {
          "type": "string",
          "default": "workspace",
          "enum": [
            "global",
            "workspace"
          ],
          "enumDescriptions": [
            "%config.defaultScope.global%",
            "%config.defaultScope.workspace%"
          ],
          "description": "%config.defaultScope%"
        },
        "copilotScheduler.language": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "en",
            "ja"
          ],
          "enumDescriptions": [
            "%config.language.auto%",
            "%config.language.en%",
            "%config.language.ja%"
          ],
          "description": "%config.language%"
        },
        "copilotScheduler.timezone": {
          "type": "string",
          "default": "",
          "description": "%config.timezone%"
        },
        "copilotScheduler.jitterSeconds": {
          "type": "number",
          "default": 600,
          "minimum": 0,
          "maximum": 1800,
          "description": "%config.jitterSeconds%"
        },
        "copilotScheduler.manualRunNextRunPolicy": {
          "type": "string",
          "default": "advance",
          "enum": [
            "advance",
            "fromNow"
          ],
          "enumDescriptions": [
            "%config.manualRunNextRunPolicy.advance%",
            "%config.manualRunNextRunPolicy.fromNow%"
          ],
          "description": "%config.manualRunNextRunPolicy%"
        },
        "copilotScheduler.chatSession": {
          "type": "string",
          "default": "new",
          "enum": [
            "new",
            "continue"
          ],
          "enumDescriptions": [
            "%config.chatSession.new%",
            "%config.chatSession.continue%"
          ],
          "description": "%config.chatSession%"
        },
        "copilotScheduler.autoModeDefault": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%config.autoModeDefault%"
        },
        "copilotScheduler.commandDelayFactor": {
          "type": "number",
          "default": 0.8,
          "minimum": 0.1,
          "maximum": 2,
          "description": "%config.commandDelayFactor%"
        },
        "copilotScheduler.showNotifications": {
          "type": "boolean",
          "default": true,
          "description": "%config.showNotifications%"
        },
        "copilotScheduler.notificationMode": {
          "type": "string",
          "default": "sound",
          "enum": [
            "sound",
            "silentToast",
            "silentStatus"
          ],
          "enumDescriptions": [
            "%config.notificationMode.sound%",
            "%config.notificationMode.silentToast%",
            "%config.notificationMode.silentStatus%"
          ],
          "description": "%config.notificationMode%"
        },
        "copilotScheduler.maxDailyExecutions": {
          "type": "integer",
          "default": 24,
          "minimum": 0,
          "maximum": 100,
          "description": "%config.maxDailyExecutions%"
        },
        "copilotScheduler.minimumIntervalWarning": {
          "type": "boolean",
          "default": true,
          "description": "%config.minimumIntervalWarning%"
        },
        "copilotScheduler.globalPromptsPath": {
          "type": "string",
          "default": "",
          "description": "%config.globalPromptsPath%"
        },
        "copilotScheduler.globalAgentsPath": {
          "type": "string",
          "default": "",
          "description": "%config.globalAgentsPath%"
        },
        "copilotScheduler.logLevel": {
          "type": "string",
          "default": "info",
          "enum": [
            "none",
            "error",
            "info",
            "debug"
          ],
          "enumDescriptions": [
            "%config.logLevel.none%",
            "%config.logLevel.error%",
            "%config.logLevel.info%",
            "%config.logLevel.debug%"
          ],
          "description": "%config.logLevel%"
        },
        "copilotScheduler.executionHistoryLimit": {
          "type": "number",
          "default": 50,
          "minimum": 10,
          "maximum": 500,
          "description": "%config.executionHistoryLimit%"
        },
        "copilotScheduler.lmTools.enableWriteTools": {
          "type": "boolean",
          "default": true,
          "description": "%config.lmTools.enableWriteTools%"
        },
        "copilotScheduler.lmTools.confirmationMode": {
          "type": "string",
          "default": "destructiveOnly",
          "enum": [
            "always",
            "destructiveOnly",
            "minimal"
          ],
          "enumDescriptions": [
            "%config.lmTools.confirmationMode.always%",
            "%config.lmTools.confirmationMode.destructiveOnly%",
            "%config.lmTools.confirmationMode.minimal%"
          ],
          "description": "%config.lmTools.confirmationMode%"
        },
        "copilotScheduler.reportIssue": {
          "type": "null",
          "markdownDescription": "%config.reportIssue%"
        }
      }
    },
    "languageModelTools": [
      {
        "name": "scheduler_query",
        "displayName": "%tool.scheduler_query.displayName%",
        "modelDescription": "%tool.scheduler_query.modelDescription%",
        "toolReferenceName": "scheduler_query",
        "canBeReferencedInPrompt": true,
        "icon": "$(list-tree)",
        "tags": [
          "copilot-scheduler"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "list",
                "get",
                "history",
                "preview_cron"
              ],
              "description": "Which kind of read to perform."
            },
            "scope": {
              "type": "string",
              "enum": [
                "global",
                "workspace",
                "all"
              ],
              "description": "For kind=list. Filter by task scope."
            },
            "enabledOnly": {
              "type": "boolean",
              "description": "For kind=list. Return only enabled tasks when true."
            },
            "id": {
              "type": "string",
              "description": "For kind=get. Task id to fetch."
            },
            "taskId": {
              "type": "string",
              "description": "For kind=history. Filter history entries to this task id."
            },
            "limit": {
              "type": "number",
              "description": "For kind=history. Max entries to return (1-500).",
              "minimum": 1,
              "maximum": 500
            },
            "cronExpression": {
              "type": "string",
              "description": "For kind=preview_cron. Cron expression to evaluate (multi-schedule supported when separated by newlines)."
            },
            "count": {
              "type": "number",
              "description": "For kind=preview_cron. Number of next occurrences (1-20).",
              "minimum": 1,
              "maximum": 20
            },
            "timezone": {
              "type": "string",
              "description": "For kind=preview_cron. IANA timezone (e.g. Asia/Tokyo)."
            }
          },
          "required": [
            "kind"
          ]
        }
      },
      {
        "name": "scheduler_create_task",
        "displayName": "%tool.scheduler_create_task.displayName%",
        "modelDescription": "%tool.scheduler_create_task.modelDescription%",
        "toolReferenceName": "scheduler_create_task",
        "canBeReferencedInPrompt": true,
        "icon": "$(add)",
        "tags": [
          "copilot-scheduler"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Human-readable task name."
            },
            "cronExpression": {
              "type": "string",
              "description": "Cron expression. Supports multiple lines separated by newlines."
            },
            "scope": {
              "type": "string",
              "enum": [
                "global",
                "workspace"
              ],
              "description": "Where the task lives. workspace requires an open folder."
            },
            "promptSource": {
              "type": "string",
              "enum": [
                "inline",
                "local",
                "global"
              ],
              "description": "Where the prompt comes from. Defaults to 'inline'."
            },
            "prompt": {
              "type": "string",
              "description": "Prompt text sent to Copilot. Always required, even when promptSource is 'local' or 'global' (use the file content)."
            },
            "promptPath": {
              "type": "string",
              "description": "Required when promptSource is 'local' or 'global'. Path relative to the resolved prompts root."
            },
            "agent": {
              "type": "string",
              "description": "Agent to use (e.g. '@workspace', 'agent', 'ask', 'edit')."
            },
            "enabled": {
              "type": "boolean",
              "description": "Whether the task is enabled after creation. Defaults to true. Enabling requires the disclaimer to be accepted."
            },
            "chatSession": {
              "type": "string",
              "enum": [
                "default",
                "new",
                "continue"
              ],
              "description": "Per-task chat session override. 'default' uses the global setting."
            }
          },
          "required": [
            "name",
            "cronExpression",
            "prompt",
            "scope"
          ]
        }
      },
      {
        "name": "scheduler_update_task",
        "displayName": "%tool.scheduler_update_task.displayName%",
        "modelDescription": "%tool.scheduler_update_task.modelDescription%",
        "toolReferenceName": "scheduler_update_task",
        "canBeReferencedInPrompt": true,
        "icon": "$(edit)",
        "tags": [
          "copilot-scheduler"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "description": "Task id to update."
            },
            "updates": {
              "type": "object",
              "description": "Fields to change. Use scheduler_set_task_enabled to toggle enabled; passing enabled here returns an error.",
              "properties": {
                "name": {
                  "type": "string"
                },
                "cronExpression": {
                  "type": "string"
                },
                "promptSource": {
                  "type": "string",
                  "enum": [
                    "inline",
                    "local",
                    "global"
                  ]
                },
                "prompt": {
                  "type": "string"
                },
                "promptPath": {
                  "type": "string"
                },
                "agent": {
                  "type": "string"
                },
                "chatSession": {
                  "type": "string",
                  "enum": [
                    "default",
                    "new",
                    "continue"
                  ]
                }
              }
            }
          },
          "required": [
            "id",
            "updates"
          ]
        }
      },
      {
        "name": "scheduler_delete_task",
        "displayName": "%tool.scheduler_delete_task.displayName%",
        "modelDescription": "%tool.scheduler_delete_task.modelDescription%",
        "toolReferenceName": "scheduler_delete_task",
        "canBeReferencedInPrompt": true,
        "icon": "$(trash)",
        "tags": [
          "copilot-scheduler"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "description": "Task id to delete. This is not recoverable."
            }
          },
          "required": [
            "id"
          ]
        }
      },
      {
        "name": "scheduler_set_task_enabled",
        "displayName": "%tool.scheduler_set_task_enabled.displayName%",
        "modelDescription": "%tool.scheduler_set_task_enabled.modelDescription%",
        "toolReferenceName": "scheduler_set_task_enabled",
        "canBeReferencedInPrompt": true,
        "icon": "$(check)",
        "tags": [
          "copilot-scheduler"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "description": "Task id."
            },
            "enabled": {
              "type": "boolean",
              "description": "True to enable, false to disable."
            }
          },
          "required": [
            "id",
            "enabled"
          ]
        }
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "copilotScheduler",
          "title": "%extension.title%",
          "icon": "images/scheduler-icon.svg"
        }
      ]
    },
    "views": {
      "copilotScheduler": [
        {
          "id": "copilotSchedulerTasks",
          "name": "%view.tasks%",
          "icon": "images/scheduler-icon.svg"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "copilotScheduler.createTaskGui",
          "when": "view == copilotSchedulerTasks",
          "group": "navigation@1"
        },
        {
          "command": "copilotScheduler.openSettings",
          "when": "view == copilotSchedulerTasks",
          "group": "navigation@2"
        },
        {
          "command": "copilotScheduler.showExecutionHistory",
          "when": "view == copilotSchedulerTasks",
          "group": "navigation@3"
        },
        {
          "command": "copilotScheduler.showVersion",
          "when": "view == copilotSchedulerTasks",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "copilotScheduler.disableTask",
          "when": "view == copilotSchedulerTasks && (viewItem == enabledTask || viewItem == enabledWorkspaceTask || viewItem == enabledOtherWorkspaceTask)",
          "group": "inline@1"
        },
        {
          "command": "copilotScheduler.enableTask",
          "when": "view == copilotSchedulerTasks && (viewItem == disabledTask || viewItem == disabledWorkspaceTask || viewItem == disabledOtherWorkspaceTask)",
          "group": "inline@1"
        },
        {
          "command": "copilotScheduler.runNow",
          "when": "view == copilotSchedulerTasks && viewItem =~ /Task$/",
          "group": "inline@2"
        },
        {
          "command": "copilotScheduler.copyPrompt",
          "when": "view == copilotSchedulerTasks && viewItem =~ /Task$/",
          "group": "inline@3"
        },
        {
          "command": "copilotScheduler.editTask",
          "when": "view == copilotSchedulerTasks && viewItem =~ /Task$/",
          "group": "inline@4"
        },
        {
          "command": "copilotScheduler.moveToCurrentWorkspace",
          "when": "view == copilotSchedulerTasks && (viewItem == enabledOtherWorkspaceTask || viewItem == disabledOtherWorkspaceTask)",
          "group": "inline@4.5"
        },
        {
          "command": "copilotScheduler.deleteTask",
          "when": "view == copilotSchedulerTasks && (viewItem == enabledTask || viewItem == disabledTask || viewItem == enabledWorkspaceTask || viewItem == disabledWorkspaceTask)",
          "group": "inline@5"
        },
        {
          "command": "copilotScheduler.runNow",
          "when": "view == copilotSchedulerTasks && viewItem =~ /Task$/",
          "group": "1_actions@1"
        },
        {
          "command": "copilotScheduler.toggleTask",
          "when": "view == copilotSchedulerTasks && viewItem =~ /Task$/",
          "group": "1_actions@2"
        },
        {
          "command": "copilotScheduler.editTask",
          "when": "view == copilotSchedulerTasks && viewItem =~ /Task$/",
          "group": "2_edit@1"
        },
        {
          "command": "copilotScheduler.duplicateTask",
          "when": "view == copilotSchedulerTasks && viewItem =~ /Task$/",
          "group": "2_edit@2"
        },
        {
          "command": "copilotScheduler.moveToCurrentWorkspace",
          "when": "view == copilotSchedulerTasks && (viewItem == enabledOtherWorkspaceTask || viewItem == disabledOtherWorkspaceTask)",
          "group": "2_edit@3"
        },
        {
          "command": "copilotScheduler.deleteTask",
          "when": "view == copilotSchedulerTasks && (viewItem == enabledTask || viewItem == disabledTask || viewItem == enabledWorkspaceTask || viewItem == disabledWorkspaceTask)",
          "group": "3_delete@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "compile": "npm run esbuild-base -- --sourcemap",
    "watch": "npm run esbuild-base -- --sourcemap --watch",
    "pretest": "tsc -p ./",
    "test": "node ./out/test/runTest.js",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "cron-parser": "^4.9.0"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.27.2",
    "eslint": "^8.0.0",
    "glob": "^10.0.0",
    "mocha": "^11.7.5",
    "typescript": "^5.0.0"
  },
  "overrides": {
    "serialize-javascript": "7.0.5",
    "diff": "9.0.0"
  }
}
